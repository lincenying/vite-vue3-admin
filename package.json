{
  "name": "vite-vue3-admin",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "author": "lincenying <lincenying@qq.com>",
  "sideEffects": false,
  "scripts": {
    "prepare[-del]": "npx simple-git-hooks",
    "serve": "cross-env DEBUG=vite:transform vite",
    "build_test": "vite build --mode test --emptyOutDir",
    "build_pre": "vite build --mode staging --emptyOutDir",
    "build_prod": "vite build --emptyOutDir",
    "start": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ts": "vue-tsc -b --noEmit",
    "lint:css": "stylelint '**/*.{css,scss}' --fix",
    "lint-staged": "lint-staged",
    "copy": "deploy_dist vite-vue3-admin"
  },
  "dependencies": {
    "@lincy/async-validation": "catalog:prod",
    "@lincy/utils": "catalog:prod",
    "@vueuse/core": "catalog:prod",
    "axios": "catalog:prod",
    "element-plus": "catalog:prod",
    "mockjs": "catalog:prod",
    "nprogress": "catalog:prod",
    "ofetch": "catalog:prod",
    "pinia": "catalog:prod",
    "qs": "catalog:prod",
    "throttle-debounce": "catalog:prod",
    "vue": "catalog:prod",
    "vue-router": "catalog:prod",
    "vuex": "catalog:prod",
    "xlsx": "catalog:prod"
  },
  "devDependencies": {
    "@iconify-json/ant-design": "catalog:icons",
    "@iconify-json/el": "catalog:icons",
    "@iconify-json/ep": "catalog:icons",
    "@iconify-json/fa": "catalog:icons",
    "@iconify-json/mdi": "catalog:icons",
    "@lincy/eslint-config": "catalog:lint",
    "@lincy/stylelint-config": "catalog:lint",
    "@lincy/unocss-base-config": "catalog:dev",
    "@types/node": "catalog:types",
    "@types/nprogress": "catalog:types",
    "@types/qs": "catalog:types",
    "@types/throttle-debounce": "catalog:types",
    "@unocss/eslint-plugin": "catalog:lint",
    "@vitejs/plugin-vue": "catalog:dev",
    "@vitejs/plugin-vue-jsx": "catalog:dev",
    "@vue-macros/volar": "catalog:dev",
    "@vue/compiler-sfc": "catalog:dev",
    "cross-env": "catalog:dev",
    "eslint": "catalog:lint",
    "eslint-plugin-format": "catalog:lint",
    "lint-staged": "catalog:lint",
    "sass-embedded": "catalog:dev",
    "stylelint": "catalog:lint",
    "typescript": "catalog:dev",
    "unocss": "catalog:dev",
    "unplugin-auto-import": "catalog:dev",
    "unplugin-icons": "catalog:dev",
    "unplugin-vue-components": "catalog:dev",
    "vite": "catalog:dev",
    "vite-plugin-inspect": "catalog:dev",
    "vite-plugin-mock": "catalog:dev",
    "vite-plugin-progress": "catalog:dev",
    "vue-component-type-helpers": "catalog:dev",
    "vue-macros": "catalog:dev",
    "vue-tsc": "catalog:dev"
  },
  "simple-git-hooks[-del]": {
    "pre-commit": "pnpm run lint-staged"
  },
  "lint-staged[-del]": {
    "*.{[jt]s?(x),vue,md}": [
      "eslint --fix"
    ],
    "*.{css,scss}": "stylelint --fix --allow-empty-input"
  }
}
